# ── Local dev secrets (copy to .env.local, never commit) ──────────────────
ELEVENLABS_API_KEY=       # ElevenLabs — animal sound generation (scripts only, not runtime)
SCENARIO_API_KEY=         # Scenario — sprite generation
SCENARIO_API_SECRET=      # Scenario — sprite generation

# ── Client build-time flags (must be NEXT_PUBLIC_* to reach the browser) ──
# Flip these to 1 to activate the live AI features.
# Without them the app runs fully offline using mock / Web Speech providers.
NEXT_PUBLIC_LLM_PROXY=0   # 1 = use the /api/chat route
NEXT_PUBLIC_TTS_PROXY=0   # 1 = use the /api/tts route

# ── Server-side secrets (NEVER prefix with NEXT_PUBLIC_) ──────────────────
LLM_PROVIDER=             # "claude" | "openai" | "deepseek"  (unset → mock)
ANTHROPIC_API_KEY=        # required when LLM_PROVIDER=claude
ANTHROPIC_BASE_URL=       # override api.anthropic.com to route via a gateway
ANTHROPIC_MODEL=          # defaults to claude-opus-4-5
ANTHROPIC_EXTRA_HEADERS=  # optional JSON of extra headers, e.g. {"x-gateway-workspace":"default"}
OPENAI_API_KEY=           # required when LLM_PROVIDER=openai
DEEPSEEK_API_KEY=         # required when LLM_PROVIDER=deepseek

TTS_PROVIDER=             # "openai"   (leave empty → client uses Web Speech API for free)
