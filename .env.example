# ── Local dev secrets (copy to .env.local, never commit) ──────────────────
ELEVENLABS_API_KEY=       # ElevenLabs — animal sound generation + TTS
SCENARIO_API_KEY=         # Scenario — sprite generation
SCENARIO_API_SECRET=      # Scenario — sprite generation

# ── Vercel build-time flags (set in Vercel dashboard → env vars) ──────────
# Flip these to 1 to activate the live AI features.
# Without them the app runs fully offline using mock providers.
VITE_LLM_PROXY=0          # 1 = use /api/chat edge function
VITE_TTS_PROXY=0          # 1 = use /api/tts edge function

# ── Vercel server-side secrets (NEVER prefix with VITE_) ─────────────────
LLM_PROVIDER=             # "claude" | "openai" | "deepseek"
ANTHROPIC_API_KEY=        # required when LLM_PROVIDER=claude
OPENAI_API_KEY=           # required when LLM_PROVIDER=openai
DEEPSEEK_API_KEY=         # required when LLM_PROVIDER=deepseek

TTS_PROVIDER=             # "elevenlabs" | "openai"   (leave empty to disable voice)
TTS_VOICE_ID=             # ElevenLabs voice ID override (optional)
